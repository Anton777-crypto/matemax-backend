# ── Сервер ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Безпека ───────────────────────────────────────────────────
# ОБОВ'ЯЗКОВО змініть це значення в продакшені!
JWT_SECRET=змініть_цей_секретний_ключ_на_довгий_рядок_2024

# ── База даних ────────────────────────────────────────────────
# За замовчуванням: ./matemax.db (поруч з server.js)
# DB_PATH=/data/matemax.db

# ── URL фронтенду (для посилань в email) ─────────────────────
FRONTEND_URL=http://localhost:3001
# В продакшені:
# FRONTEND_URL=https://your-domain.com

# ── Адмін за замовчуванням (тільки при першому запуску) ──────
ADMIN_EMAIL=admin@matemax.com
ADMIN_PASSWORD=admin123

# ── Email (необов'язково — для верифікації та скидання пароля)
# Якщо не вказано — посилання виводяться в консоль
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM=МатеМакс <your-email@gmail.com>

# ── CORS (необов'язково) ──────────────────────────────────────
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
